# Application
APP_ENV=development
APP_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=goaconly
DB_PASSWORD=goaconly_secret
DB_NAME=goaconly_db
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_TIMEOUT=5s

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=2
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# Rate Limiting (системная защита API)
RATE_LIMIT_DEFAULT_RPS=10
RATE_LIMIT_AUTH_RPS=3
RATE_LIMIT_WINDOW=1s

# Cache
CACHE_SITE_STATUS_TTL=30s

# JWT (заполним на неделе 6)
JWT_SECRET=change_me_in_production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h